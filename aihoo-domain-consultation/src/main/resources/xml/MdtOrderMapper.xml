<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aihoo.domain.consultation.model.mapper.MdtOrderMapper">

    <select id="selectListByDoctorIdCard" resultType="com.aihoo.domain.consultation.model.entity.MdtOrder">
        SELECT DISTINCT tmo.*
        FROM t_mdt_order tmo
        LEFT JOIN t_mdt_order_doctor tmod ON tmo.id = tmod.mdt_order_id
        WHERE tmod.doctor_user_id = #{doctorUserId}
          AND tmo.mdt_appointment_time is not null
        <if test="null != statusList and statusList.size > 0">
            AND tmo.STATUS IN
            <foreach collection="statusList" item="item" index="index" open="(" close=")" separator=",">
                #{item}
            </foreach>
        </if>
        ORDER BY tmo.create_time desc
    </select>
</mapper>
