<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--======================================= 本地变量 ======================================== -->



    <!--在没有定义${LOG_HOME}系统变量的时候，可以设置此本地变量。提交测试、上线时，要将其注释掉，使用系统变量。 -->

    <property name="LOG_HOME" value="logs"/>

    <!--日志文件保留天数 -->


    <property value="30" name="LOG_MAX_HISTORY"/>


    <!-- 控制台输出 -->


    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">


        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">

            <!--格式化输出：%d表示日期，%thread表示线程名，%-5level：级别从左显示5个字符宽度%msg：日志消息，%n是换行符 -->


            <pattern>%yellow(%d{yyyy-MM-dd HH:mm:ss.SSS}) [%blue(%thread)] %-5level %logger{50} - %blue(%msg%n)</pattern>

            <charset>UTF-8</charset>
        </encoder>

    </appender>

    <!-- 按照每天生成日志文件：主项目日志 -->
    <appender name="APP" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>DEBUG</level>

        </filter>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">

            <!--日志文件输出的文件名 -->


            <FileNamePattern>${LOG_HOME}/patient_info.%d.log</FileNamePattern>

            <!--日志文件保留天数 -->


            <MaxHistory>${LOG_MAX_HISTORY}</MaxHistory>

        </rollingPolicy>


        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">

            <!--格式化输出：%d表示日期，%thread表示线程名，%-5level：级别从左显示5个字符宽度%msg：日志消息，%n是换行符 -->

            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{500} - %msg%n</pattern>
            <!-- 记录日志的编码:此处设置字符集 - -->
            <charset>UTF-8</charset>
        </encoder>

    </appender>

    <!-- 按照每天生成日志文件：主项目日志 -->
    <appender name="ErrorLog" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">

            <!--日志文件输出的文件名 -->


            <FileNamePattern>${LOG_HOME}/patient_error.%d.log</FileNamePattern>

            <!--日志文件保留天数 -->


            <MaxHistory>${LOG_MAX_HISTORY}</MaxHistory>

        </rollingPolicy>


        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">

            <!--格式化输出：%d表示日期，%thread表示线程名，%-5level：级别从左显示5个字符宽度%msg：日志消息，%n是换行符 -->

            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{500} - %msg%n</pattern>
            <!-- 记录日志的编码:此处设置字符集 - -->
            <charset>UTF-8</charset>
        </encoder>

    </appender>

    <!--=============================== 日志输出: 默认主业务日志 ====================================== -->

    <logger name="org.springframework"></logger>


    <logger name="freemarker"></logger>


    <logger name="org.mybatis"></logger>


    <logger name="org.mybatis.SQL"></logger>

    <!-- 指定项目中某个包，当有日志操作行为时的日志记录级别 -->
    <!-- com.auction为根包，也就是只要是发生在这个根包下面的所有日志操作行为的权限都是DEBUG -->
    <!-- 级别依次为【从高到低】：FATAL > ERROR > WARN > INFO > DEBUG > TRACE  -->
    <!--单独指定日志级别 优先级高于全局-->
    <logger name="com.patient">
        <level value="DEBUG"/>
    </logger>

    <root level="INFO">

        <appender-ref ref="APP"/>
        <!-- 控制台输出 -->
        <appender-ref ref="STDOUT"/>
        <!--错误日志-->
        <appender-ref ref="ErrorLog"/>

    </root>

</configuration>