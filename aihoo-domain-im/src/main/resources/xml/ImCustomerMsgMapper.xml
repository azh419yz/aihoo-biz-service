<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aihoo.domain.im.model.mapper.ImCustomerMsgMapper">
    <sql id="Base_Column_List">
    id, create_time, update_time, create_time_str, admin_id, patient_id, from_account,
    to_account, msg_seq, msg_random, msg_time, msg_key, send_msg_result, error_info
    </sql>
    <select id="customerDetails" resultType="java.lang.String">
     SELECT patient_id FROM t_im_customer_msg WHERE
     admin_id = #{map.adminId}
        <if test="map.startTime!=null and map.startTime !=''">
            AND msg_time <![CDATA[>= ]]> #{map.startTime}
        </if>
        <if test="map.endTime!=null and map.endTime !=''">
            AND msg_time <![CDATA[<= ]]> #{map.endTime}
        </if>
        GROUP BY patient_id
    </select>

    <select id="findStartTime" resultMap="BaseResultMap">
         SELECT
         a.id, a.create_time, a.update_time, a.create_time_str, a.admin_id, a.patient_id, a.from_account,
         a.to_account, a.msg_seq, a.msg_random, a.msg_time, a.msg_key, a.send_msg_result, a.error_info,
         b.id as contentId , b.create_time, b.update_time, b.create_time_str, b.msg_type, b.msg_type_name, b.msg_content
          FROM
         t_im_customer_msg a LEFT JOIN  t_im_msg_customer_content b ON a.id = b.im_msg_id
         WHERE  admin_id = #{adminId} AND patient_id = #{patientId}
    </select>

    <resultMap id="BaseResultMap" type="com.aihoo.domain.im.model.entity.ImCustomerMsg">
        <id column="id" jdbcType="BIGINT" property="id" />
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
        <result column="update_time" jdbcType="TIMESTAMP" property="updateTime" />
        <result column="create_time_str" jdbcType="VARCHAR" property="createTimeStr" />
        <result column="admin_id" jdbcType="BIGINT" property="adminId" />
        <result column="patient_id" jdbcType="BIGINT" property="patientId" />
        <result column="from_account" jdbcType="VARCHAR" property="fromAccount" />
        <result column="to_account" jdbcType="VARCHAR" property="toAccount" />
        <result column="msg_seq" jdbcType="BIGINT" property="msgSeq" />
        <result column="msg_random" jdbcType="VARCHAR" property="msgRandom" />
        <result column="msg_time" jdbcType="VARCHAR" property="msgTime" />
        <result column="msg_key" jdbcType="VARCHAR" property="msgKey" />
        <result column="send_msg_result" jdbcType="VARCHAR" property="sendMsgResult" />
        <result column="error_info" jdbcType="VARCHAR" property="errorInfo" />
        <collection property="payloads" ofType="com.aihoo.domain.im.model.entity.ImMsgCustomerContent">
            <id column="contentId" jdbcType="BIGINT" property="id" />
            <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
            <result column="update_time" jdbcType="TIMESTAMP" property="updateTime" />
            <result column="create_time_str" jdbcType="VARCHAR" property="createTimeStr" />
            <result column="msg_type" jdbcType="VARCHAR" property="msgType" />
            <result column="msg_type_name" jdbcType="VARCHAR" property="msgTypeName" />
            <result column="msg_content" jdbcType="VARCHAR" property="msgContent" />
            <result column="im_msg_id" jdbcType="BIGINT" property="imMsgId" />
        </collection>
    </resultMap>
</mapper>
