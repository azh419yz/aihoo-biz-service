<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aihoo.domain.visit.model.mapper.HosVisitImgMapper">
    <select id="selectByHosVisitId" resultType="com.aihoo.domain.visit.model.entity.HosVisitImg">
        select id, create_time, update_time, hos_visit_id, img, `index`
        FROM t_hos_visit_img
        WHERE hos_visit_id = #{id,jdbcType=VARCHAR}
    </select>
</mapper>
